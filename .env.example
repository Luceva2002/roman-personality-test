# Public URL of the deployed app (used by Frame/OG metadata and NFT image URIs).
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Optional but recommended: enables WalletConnect.
# Get a free Project ID at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: customize the Farcaster Mini App manifest.
MINIAPP_NAME=Boro, Coatto o Pariolino?
MINIAPP_WEBHOOK_URL=
BASE_ALLOWED_ADDRESSES=

# Only required for `npm run setup-contract` (writes baseImageURI to chain).
# Never commit this value.
PRIVATE_KEY=
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
